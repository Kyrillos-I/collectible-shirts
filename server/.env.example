NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/collectible_shirts

# Production must replace this with a strong random secret.
JWT_SECRET=change-me

# Same-origin deploys can keep the defaults below. If the frontend is deployed
# on a different origin, set COOKIE_SAME_SITE=none and COOKIE_SECURE=true.
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

LOGIN_CODE_TTL_MINUTES=10
RESEND_API_KEY=
RESEND_FROM_EMAIL=
